# Red Alpha Companion — environment variables
# Copy to ".env" and fill in. NEVER commit the real .env.
# Client-exposed values must use the EXPO_PUBLIC_ prefix.

# --- Supabase (client-safe; protected by Row Level Security) ---
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_KEY   # use sb_publishable_... (legacy anon keys deprecated end of 2026)

# --- Microsoft Entra (Azure AD) sign-in ---
# These currently live in app.json > expo.extra; move to env for production.
# AZURE_AD_CLIENT_ID=...
# AZURE_AD_TENANT_ID=...

# --- Server-side ONLY. Do NOT put these in the client bundle / EXPO_PUBLIC_. ---
# Configure as EAS secrets or in a Supabase Edge Function instead.
# MOODLE_BASE_URL=https://your-moodle/webservice/rest/server.php
# MOODLE_API_TOKEN=...
# SUPABASE_SERVICE_ROLE_KEY=...
