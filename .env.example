# Red Alpha Companion — environment variables
# Copy this file to ".env" and fill in. NEVER commit the real ".env" (it is git-ignored).
# In CI/hosting, set the SAME names as GitHub Actions "secrets" (and in EAS for mobile).
#
# Only values prefixed EXPO_PUBLIC_ are read by the app. They are embedded in the build and
# are therefore PUBLIC by design — that is fine for these (Supabase is protected by Row Level
# Security; the Azure client/tenant IDs are not secrets). Do NOT put real secrets here.

# --- Supabase (backend) ---
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_KEY

# --- Microsoft Entra (Azure AD) sign-in ---
EXPO_PUBLIC_AZURE_AD_CLIENT_ID=YOUR_APPLICATION_CLIENT_ID
EXPO_PUBLIC_AZURE_AD_TENANT_ID=YOUR_DIRECTORY_TENANT_ID   # or "common" for multi-tenant

# --- First-run admin bootstrap ---
# Comma-separated emails that are ALWAYS treated as admin (use this to make yourself
# admin before the members list/Supabase exists). Everyone else defaults to student
# unless invited as staff/admin from the Users tab.
EXPO_PUBLIC_ADMIN_EMAILS=you@yourcompany.com

# Optional: restrict sign-in to these email domains (comma-separated). Empty = allow all.
EXPO_PUBLIC_ALLOWED_EMAIL_DOMAINS=redalphacyber.com

# --- Optional custom REST backend base URL (leave blank if unused) ---
EXPO_PUBLIC_API_BASE_URL=

# ------------------------------------------------------------------------------------------
# SERVER-SIDE ONLY — never goes in the app / never EXPO_PUBLIC_.
# Configure these as Supabase Edge Function secrets (or another server), not here:
#   MOODLE_BASE_URL, MOODLE_API_TOKEN, SUPABASE_SERVICE_ROLE_KEY
# ------------------------------------------------------------------------------------------
